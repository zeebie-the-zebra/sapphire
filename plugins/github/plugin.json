{
  "name": "github",
  "short_display_name": "GitHub",
  "version": "1.0.0",
  "description": "GitHub — repos, files, issues, search. PAT-authenticated, scope-aware multi-account.",
  "author": "sapphire",
  "url": "https://sapphireblue.dev",
  "icon": "🐙",
  "priority": 50,
  "default_enabled": false,
  "capabilities": {
    "tools": ["tools/github.py"],
    "scopes": [
      {
        "key": "github",
        "label": "github",
        "endpoint": "/api/github/accounts",
        "data_key": "accounts",
        "value_field": "scope",
        "name_field": "scope",
        "label_template": "{label}"
      }
    ],
    "routes": [
      {
        "method": "POST",
        "path": "validate",
        "handler": "routes/accounts.py:validate_token"
      }
    ]
  }
}

{
  "name": "piper",
  "version": "1.0.0",
  "description": "Piper — fast local neural TTS for CPU / weak hardware",
  "author": "sapphire",
  "icon": "🗣️",
  "priority": 50,
  "default_enabled": false,
  "pip_dependencies": ["piper-tts"],
  "settingsUI": null,
  "capabilities": {
    "providers": {
      "tts": {
        "key": "piper",
        "display_name": "Piper (Local, fast-CPU)",
        "entry": "provider.py",
        "class_name": "PiperTTSProvider"
      }
    },
    "settings": [
      {
        "key": "voice",
        "type": "select",
        "label": "Voice",
        "default": "en_US-hfc_female-medium",
        "help": "Downloaded on first use into user/piper-voices/. Medium = better quality; low = 16kHz, faster, smaller data.",
        "options": [
          {"value": "en_US-hfc_female-medium", "label": "HFC Female — medium (default)"},
          {"value": "en_US-kristin-medium", "label": "Kristin — medium"},
          {"value": "en_US-lessac-medium", "label": "Lessac — medium"},
          {"value": "en_US-ljspeech-medium", "label": "LJSpeech — medium"},
          {"value": "en_US-amy-medium", "label": "Amy — medium"},
          {"value": "en_US-amy-low", "label": "Amy — low (fast, 16kHz)"},
          {"value": "en_US-kathleen-low", "label": "Kathleen — low (fast, 16kHz)"},
          {"value": "en_US-lessac-low", "label": "Lessac — low (fast, 16kHz)"}
        ]
      },
      {
        "key": "threads",
        "type": "number",
        "label": "CPU threads",
        "default": 0,
        "help": "Intra-op threads for synthesis. 0 = onnxruntime default (all cores). On weak/hybrid CPUs set to physical-core count; avoid oversubscribing (12 hurts)."
      }
    ]
  }
}

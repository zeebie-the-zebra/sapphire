{
  "name": "avatar",
  "short_display_name": "Avatar",
  "version": "1.1.0",
  "description": "3D Avatar \u2014 animated presence that reacts to Sapphire's state in real-time",
  "author": "sapphire",
  "icon": "\ud83d\udc8e",
  "priority": 80,
  "default_enabled": false,
  "settingsUI": "plugin",
  "capabilities": {
    "sidebar_accordion": {
      "title": "Avatar",
      "icon": "\ud83d\udc8e",
      "content": "sidebar.html",
      "script": "sidebar.js"
    },
    "hooks": {
      "prompt_inject": "hooks/prompt_inject.py"
    },
    "routes": [
      {"method": "GET",    "path": "models",            "handler": "routes/api.py:list_models"},
      {"method": "POST",   "path": "upload",            "handler": "routes/api.py:upload_model"},
      {"method": "DELETE", "path": "models/{filename}",  "handler": "routes/api.py:delete_model"},
      {"method": "GET",    "path": "tracks/{filename}",  "handler": "routes/api.py:get_tracks"},
      {"method": "GET",    "path": "config",             "handler": "routes/api.py:get_config"},
      {"method": "PUT",    "path": "config",             "handler": "routes/api.py:save_config"}
    ]
  }
}

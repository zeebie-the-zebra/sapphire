{
  "name": "webcam",
  "short_display_name": "Webcam",
  "version": "1.0.0",
  "description": "Webcam capture — lets the AI see through your camera",
  "author": "sapphire",
  "icon": "📷",
  "priority": 50,
  "capabilities": {
    "tools": ["tools/webcam.py"],
    "routes": [
      {
        "method": "GET",
        "path": "pending",
        "handler": "routes/capture.py:get_pending"
      },
      {
        "method": "POST",
        "path": "capture",
        "handler": "routes/capture.py:handle_capture"
      }
    ]
  }
}

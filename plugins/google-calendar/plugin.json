{
  "name": "google-calendar",
  "short_display_name": "Google Calendar",
  "version": "1.0.0",
  "description": "Google Calendar — view schedule, add and remove events",
  "author": "sapphire",
  "url": "https://sapphireblue.dev",
  "icon": "\ud83d\udcc5",
  "priority": 50,
  "default_enabled": false,
  "capabilities": {
    "tools": ["tools/calendar.py"],
    "cleanup_paths": ["plugin_state/gcal-csrf.json"],
    "scopes": [
      {
        "key": "gcal",
        "label": "calendar",
        "endpoint": "/api/gcal/accounts",
        "data_key": "accounts",
        "value_field": "scope",
        "name_field": "scope",
        "label_template": "{label}"
      }
    ],
    "routes": [
      {
        "method": "GET",
        "path": "auth",
        "handler": "routes/oauth.py:start_auth"
      },
      {
        "method": "GET",
        "path": "callback",
        "handler": "routes/oauth.py:handle_callback"
      },
      {
        "method": "GET",
        "path": "status",
        "handler": "routes/oauth.py:get_status"
      },
      {
        "method": "POST",
        "path": "disconnect",
        "handler": "routes/oauth.py:disconnect"
      }
    ],
    "settings": [
      {
        "key": "GCAL_CLIENT_ID",
        "type": "string",
        "label": "Google Client ID",
        "default": "",
        "help": "OAuth2 Client ID from Google Cloud Console (APIs & Services > Credentials)"
      },
      {
        "key": "GCAL_CLIENT_SECRET",
        "type": "string",
        "label": "Google Client Secret",
        "default": "",
        "help": "OAuth2 Client Secret from Google Cloud Console"
      },
      {
        "key": "GCAL_CALENDAR_ID",
        "type": "string",
        "label": "Calendar ID",
        "default": "primary",
        "help": "Which calendar to use. 'primary' for your main calendar, or a specific calendar ID."
      },
      {
        "key": "GCAL_CONNECT",
        "type": "string",
        "widget": "button",
        "label": "Google Account",
        "button_label": "Connect Google Calendar",
        "button_label_connected": "Connected ✓",
        "action": "/api/plugin/google-calendar/auth",
        "status": "/api/plugin/google-calendar/status",
        "disconnect": "/api/plugin/google-calendar/disconnect",
        "help": "Authorize Sapphire to access your Google Calendar. Add your redirect URI in Google Console first."
      }
    ]
  }
}
